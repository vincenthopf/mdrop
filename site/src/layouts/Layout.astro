---
interface Props {
	title: string;
	description?: string;
}

const { title, description = 'One command. Terminal to styled webpage in 3 seconds. Self-hosted, open source, free.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" href="/images/mdrop-logo.png" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/images/mdrop-og.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/images/mdrop-og.png" />
		<title>{title}</title>
	</head>
	<body class="overflow-x-hidden">
		<slot />
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>
