---
---

<section class="relative pt-32 md:pt-40 pb-16 md:pb-24 text-center" id="hero">
	<!-- Glow -->
	<div class="absolute top-16 left-1/2 -translate-x-1/2 w-[85vw] h-[85vw] max-w-[600px] max-h-[600px] bg-[radial-gradient(circle,var(--color-accent-glow)_0%,transparent_70%)] pointer-events-none" />

	<div class="relative max-w-7xl mx-auto px-6">
		<div data-animate="fade-down">
			<span class="inline-block border-2 border-accent px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-accent-light mb-8">
				Open Source &middot; Self-Hosted &middot; Free
			</span>
		</div>

		<h1 data-animate="fade-up" class="text-4xl min-[375px]:text-5xl md:text-8xl lg:text-[7rem] font-black uppercase tracking-tighter leading-[0.9] text-white mb-6">
			One Command.<br />
			<span class="text-accent">Instant Page.</span>
		</h1>

		<p data-animate="fade-up" data-delay="0.1" class="text-lg md:text-xl text-fg-muted max-w-lg mx-auto mb-12 leading-relaxed">
			Turn any markdown file into a beautifully styled, shareable webpage. No deploy. No config. Just drop it.
		</p>

		<div data-animate="fade-up" data-delay="0.2" class="max-w-xl mx-auto text-left">
			<div class="relative bg-bg-code border-2 border-border-heavy shadow-[4px_4px_0_var(--color-accent)] md:shadow-[8px_8px_0_var(--color-accent)] p-6 md:p-8">
				<span class="absolute -top-3 left-4 bg-bg px-2 text-[0.65rem] text-accent font-bold tracking-widest uppercase">
					Terminal
				</span>
				<div class="space-y-2 text-sm md:text-base">
					<div><span class="text-accent">$ </span><span class="text-white">mdrop README.md --theme brutalist</span></div>
					<div class="text-fg-muted">Rendering with brutalist theme...</div>
					<div class="text-fg-muted">Uploading...</div>
					<div class="h-4" />
					<div class="text-success">https://mdrop.workers.dev/a1b2c3d4</div>
				</div>
			</div>
		</div>

		<div data-animate="fade-up" data-delay="0.4" class="mt-16 max-w-4xl mx-auto">
			<div class="border-2 border-border-heavy shadow-[4px_4px_0_var(--color-accent)] md:shadow-[8px_8px_0_var(--color-accent)]">
				<img
					src="/images/mdrop-transform.png"
					alt="mDrop transforms a terminal command into a beautifully styled webpage"
					class="w-full block"
					loading="lazy"
				/>
			</div>
		</div>
	</div>
</section>
