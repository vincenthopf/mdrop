---
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/95 backdrop-blur-sm border-b-2 border-border">
	<div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-14">
		<a href="/" class="flex items-center gap-2.5 no-underline">
			<img src="/images/mdrop-logo.png" alt="mDrop" class="h-10 w-10" />
			<span class="text-xl font-black uppercase tracking-wider text-white"><span class="text-accent">m</span>Drop</span>
		</a>
		<ul data-nav-desktop class="hidden md:flex items-center gap-6 list-none m-0 p-0">
			<li><a href="/#how" class="text-fg-muted text-xs font-bold uppercase tracking-wider no-underline hover:text-accent-light transition-colors">How It Works</a></li>
			<li><a href="/#themes" class="text-fg-muted text-xs font-bold uppercase tracking-wider no-underline hover:text-accent-light transition-colors">Themes</a></li>
			<li><a href="/#features" class="text-fg-muted text-xs font-bold uppercase tracking-wider no-underline hover:text-accent-light transition-colors">Features</a></li>
			<li>
				<a href="/get-started" class="inline-block px-5 py-2 bg-accent text-white text-xs font-bold uppercase tracking-wider no-underline border-2 border-accent hover:bg-transparent hover:text-accent-light transition-all">
					Get Started
				</a>
			</li>
			<li>
				<a href="https://github.com/vincenthopf/mdrop" class="text-fg-muted text-xs font-bold uppercase tracking-wider no-underline hover:text-accent-light transition-colors">
					GitHub
				</a>
			</li>
		</ul>
		<button
			id="mobile-nav-toggle"
			type="button"
			class="md:hidden inline-flex h-10 w-10 items-center justify-center border-2 border-border text-white hover:border-accent hover:text-accent-light"
			aria-controls="mobile-nav-overlay"
			aria-expanded="false"
			aria-label="Open navigation menu"
		>
			<span class="sr-only">Toggle navigation menu</span>
			<span aria-hidden="true" class="flex flex-col gap-1.5">
				<span class="block h-0.5 w-5 bg-current"></span>
				<span class="block h-0.5 w-5 bg-current"></span>
				<span class="block h-0.5 w-5 bg-current"></span>
			</span>
		</button>
	</div>
</nav>

<div
	id="mobile-nav-overlay"
	class="fixed inset-0 z-40 hidden bg-bg px-6 pt-20 pb-8 md:hidden"
	aria-hidden="true"
>
	<nav aria-label="Mobile navigation" class="h-full">
		<ul class="flex h-full flex-col gap-4 list-none m-0 p-0">
			<li><a href="/#how" class="block border-2 border-border px-4 py-4 text-3xl font-black uppercase tracking-wider text-white no-underline hover:border-accent hover:text-accent-light">How It Works</a></li>
			<li><a href="/#themes" class="block border-2 border-border px-4 py-4 text-3xl font-black uppercase tracking-wider text-white no-underline hover:border-accent hover:text-accent-light">Themes</a></li>
			<li><a href="/#features" class="block border-2 border-border px-4 py-4 text-3xl font-black uppercase tracking-wider text-white no-underline hover:border-accent hover:text-accent-light">Features</a></li>
			<li><a href="/get-started" class="block border-2 border-accent bg-accent px-4 py-4 text-3xl font-black uppercase tracking-wider text-white no-underline hover:bg-transparent hover:text-accent-light">Get Started</a></li>
			<li class="mt-auto pt-4 border-t-2 border-border">
				<a href="https://github.com/vincenthopf/mdrop" class="block border-2 border-border px-4 py-4 text-2xl font-black uppercase tracking-wider text-white no-underline hover:border-accent hover:text-accent-light">GitHub</a>
			</li>
		</ul>
	</nav>
</div>

<script>
	const toggle = document.getElementById('mobile-nav-toggle')!;
	const overlay = document.getElementById('mobile-nav-overlay')!;
	const mobileLinks = overlay.querySelectorAll('a');

	function openMenu() {
		overlay.classList.remove('hidden');
		document.body.classList.add('overflow-hidden');
		toggle.setAttribute('aria-expanded', 'true');
		overlay.setAttribute('aria-hidden', 'false');
		const firstLink = overlay.querySelector('a');
		if (firstLink) firstLink.focus();
	}

	function closeMenu() {
		overlay.classList.add('hidden');
		document.body.classList.remove('overflow-hidden');
		toggle.setAttribute('aria-expanded', 'false');
		overlay.setAttribute('aria-hidden', 'true');
		toggle.focus();
	}

	toggle.addEventListener('click', () => {
		const isOpen = toggle.getAttribute('aria-expanded') === 'true';
		if (isOpen) {
			closeMenu();
		} else {
			openMenu();
		}
	});

	mobileLinks.forEach((link) => {
		link.addEventListener('click', () => {
			closeMenu();
		});
	});

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
			closeMenu();
		}
	});

	window.addEventListener('resize', () => {
		if (window.innerWidth >= 768 && toggle.getAttribute('aria-expanded') === 'true') {
			closeMenu();
		}
	});
</script>
