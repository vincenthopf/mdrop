---
---

<section class="py-24 border-t-2 border-border" id="install">
	<div class="max-w-7xl mx-auto px-6">
		<div class="text-center mb-16" data-animate="fade-up">
			<span class="block text-xs font-bold tracking-widest text-accent mb-3">/05 GET STARTED</span>
			<h2 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tight leading-none text-white">
				Two Steps. Seriously.
			</h2>
			<p class="mt-4 text-fg-muted max-w-lg mx-auto">
				One click deploys the worker. One install gets the CLI. That's it.
			</p>
		</div>

		<div class="max-w-2xl mx-auto space-y-10">
			<!-- Step 1: Deploy Button -->
			<div data-animate="fade-up" data-delay="0.1">
				<div class="text-[0.7rem] text-accent font-bold tracking-widest uppercase mb-3">/01 Deploy your worker</div>
				<div class="bg-bg-card border-2 border-border p-8 text-center">
					<p class="text-fg-muted text-sm mb-6">
						Click the button. Cloudflare handles the rest — clones the repo, provisions KV storage, sets up CI/CD. Done in seconds.
					</p>
					<a
						href="https://deploy.workers.cloudflare.com/?url=https://github.com/vincenthopf/mdrop/tree/main/worker"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block"
					>
						<img
							src="https://deploy.workers.cloudflare.com/button"
							alt="Deploy to Cloudflare Workers"
							class="h-12"
						/>
					</a>
					<p class="text-fg-muted text-xs mt-5">
						After deploy, set your API key: <code class="text-accent-light bg-bg-code px-2 py-0.5 border border-border text-xs">wrangler secret put API_KEY</code>
					</p>
				</div>
			</div>

			<!-- Step 2: Install + Configure -->
			<div data-animate="fade-up" data-delay="0.2">
				<div class="text-[0.7rem] text-accent font-bold tracking-widest uppercase mb-3">/02 Install &amp; share</div>
				<div class="bg-bg-code border-2 border-border p-5 overflow-x-auto">
					<pre class="text-sm leading-relaxed"><span class="text-fg-muted"># Install the CLI</span>
<span class="text-accent-light">npm install -g mdrop</span>

<span class="text-fg-muted"># Point it at your worker</span>
<span class="text-accent-light">mdrop init</span>

<span class="text-fg-muted"># Drop it</span>
<span class="text-accent-light">mdrop README.md --theme brutalist</span>
<span class="text-success"># → https://mdrop.workers.dev/a1b2c3d4</span></pre>
				</div>
			</div>
		</div>
	</div>
</section>
